# Your local Gemini API endpoint for development.
# Use a shim or actual Gemini Flask server here.
GEMINI_API_URL=http://localhost:5000/generate
GEMINI_API_KEY=

# Optional LangSmith tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=hr-assistant

# Google OAuth paths
GOOGLE_CREDENTIALS_PATH=./backend/google_credentials/credentials.json
GOOGLE_TOKEN_PATH=./backend/google_credentials/token.json

# ChromaDB
CHROMA_DB_PATH=./backend/chroma_db
CHROMA_COLLECTION_NAME=hr_policies

# FastAPI backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
